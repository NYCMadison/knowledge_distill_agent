# DeepSeek 蒸馏 API（复制到 scripts/.env.distill 后填入真实值，勿提交 .env.distill）
# 运行前: conda activate ikb_env，使用 python 运行脚本

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DISTILL_LLM_MODEL=deepseek-chat

# 路径由运行环境设置（迁移时必设）：
# KB_VENTURE=<知识库根路径>   # 迁移目标 about_* 的根
# DISTILL_PROJECT_ROOT=<项目根> # 可选，默认脚本父目录
